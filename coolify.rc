# Contagent — Coolify Environment Variables
# Copy values into the Coolify dashboard Environment Variables tab.
#
# BUILD VARIABLES: check the "Build Variable" checkbox for each of these.
# RUNTIME VARIABLES: leave "Build Variable" unchecked.
#
# Do NOT commit this file with real values.

# =============================================================================
# BUILD VARIABLES (check "Build Variable" in Coolify)
# =============================================================================

USERNAME=sortie
SSH_KEY=
SSH_PASSWORD=

# =============================================================================
# RUNTIME VARIABLES (no "Build Variable" checkbox needed)
# =============================================================================

# Anthropic / Claude Code
ANTHROPIC_API_KEY=

# GitHub
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_REPO=

# Sortie AI
SORTIE_GITHUB_TOKEN=
SORTIE_GITHUB_PROJECT=

# Expo / EAS
EXPO_TOKEN=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
